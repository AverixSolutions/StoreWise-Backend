// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  USER
}

enum SaleType {
  DIRECT
  FRANCHISE
}

enum Unit {
  KG
  NOS
  LTR
  MTR
}

enum TaxPercent {
  NT
  P5
  P12
  P18
  P28
}

model User {
  id        String   @id @default(uuid())
  userId    String   @unique
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  licenseId String?
  license   License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  Purchase Purchase[]
}

model License {
  id          String   @id
  name        String
  maxUsers    Int      @default(1)
  activeUntil DateTime
  isActive    Boolean  @default(true)

  saleType           SaleType @default(DIRECT)
  customerName       String
  customerPhone      String
  amountPaid         Decimal  @db.Decimal(10, 2)
  franchiseId        String?
  marginForUs        Decimal  @db.Decimal(10, 2)
  marginForFranchise Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  roleLimits LicenseRoleLimit[]

  franchise Franchise? @relation(fields: [franchiseId], references: [id])

  products  Product[]
  purchases Purchase[]
}

model Franchise {
  id          String    @id @default(uuid())
  name        String
  contactName String
  phone       String
  email       String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  licenses    License[]
}

model LicenseRoleLimit {
  id         String   @id @default(uuid())
  licenseId  String
  role       Role
  maxScreens Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, role])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime @default(dbgenerated("now() + interval '1 year'"))
  revoked    Boolean  @default(false)
  deviceInfo String?
  ip         String?

  @@unique([userId, deviceInfo])
  @@index([userId])
}

model Product {
  id         String     @id @default(uuid())
  licenseId  String
  code       String
  codeNumber Int
  name       String
  brand      String?
  category   String?
  unit       Unit
  tax        TaxPercent
  hsn        String?
  costPrice  Decimal    @db.Decimal(10, 2)
  salePrice  Decimal?   @db.Decimal(10, 2)
  stock      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime

  deletedAt DateTime?

  license   License        @relation(fields: [licenseId], references: [id])
  purchases PurchaseItem[]

  isSynced Boolean   @default(false)
  syncedAt DateTime?

  @@unique([licenseId, code])
  @@unique([licenseId, codeNumber])
  @@index([licenseId, code])
  @@index([licenseId, name])
  @@index([isSynced])
}

model Purchase {
  id           String   @id @default(uuid())
  userId       String
  licenseId    String
  purchaseDate DateTime @default(now())
  totalAmount  Decimal  @db.Decimal(10, 2)
  discount     Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id])
  license License        @relation(fields: [licenseId], references: [id])
  items   PurchaseItem[]

  isSynced Boolean   @default(false)
  syncedAt DateTime?

  @@index([licenseId, purchaseDate])
  @@index([isSynced])
}

model PurchaseItem {
  id         String     @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  unit       Unit
  rate       Decimal    @db.Decimal(10, 2)
  taxPercent TaxPercent
  taxAmount  Decimal    @db.Decimal(10, 2)
  discount   Decimal?   @db.Decimal(10, 2)
  salePrice  Decimal?   @db.Decimal(10, 2)
  profit     Decimal?   @db.Decimal(10, 2)
  totalCost  Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  isSynced Boolean   @default(false)
  syncedAt DateTime?

  @@index([isSynced])
}
